//@version=5
// ════════════════════════════════════════════════════════════════
//  DCA Bot Backtest — 3Commas tarzı (DCA-BACKTEST uygulamasının kopyası)
//  Base Order + Safety Orders + Martingale (hacim & sapma çarpanı)
//  + TP / TTP + Kâr Reinvest. Komisyon her alım ve satımda uygulanır.
//
//  NOT — pyramiding=1000: TradingView motorunun "aynı yönde kaç emir
//  açık kalabilir" tavanıdır. maxSO senin mantığın; pyramiding sadece
//  motorun bu emirleri reddetmemesi için yeterince yüksek tutulur
//  (pyramiding sabit olmak zorunda, input olamaz).
// ════════════════════════════════════════════════════════════════
strategy("DCA Bot Backtest",
     overlay              = true,
     initial_capital      = 10000,
     currency             = currency.USD,
     commission_type      = strategy.commission.percent,
     commission_value     = 0.1,
     pyramiding           = 1000,
     default_qty_type     = strategy.fixed,
     process_orders_on_close = true,
     calc_on_every_tick   = false)

// ─── Parametreler (uygulamadaki varsayılanlar) ───────────────────
baseOrder = input.float(100,  "Base Order ($)",             group="DCA")
safeOrder = input.float(100,  "Safety Order ($)",           group="DCA")
maxSO     = input.int  (10,   "Max Safety Orders",          group="DCA", minval=0, maxval=50)
priceStep = input.float(1.0,  "Price Deviation % (ilk SO)", group="DCA", step=0.1)
stepMult  = input.float(1.0,  "Step Scale (sapma çarpanı)", group="DCA", step=0.05)
volMult   = input.float(1.0,  "Volume Scale (tutar çarpanı)", group="DCA", step=0.05)
tpPct     = input.float(1.5,  "Take Profit %",              group="DCA", step=0.1)
useTTP    = input.bool (false,"Trailing Take Profit",       group="DCA")
ttpPct    = input.float(0.5,  "TTP Deviation %",            group="DCA", step=0.1)

// ─── Reinvest ────────────────────────────────────────────────────
reinvest    = input.bool (false, "Kârı Reinvest Et",  group="Reinvest")
reinvestPct = input.float(100,   "Reinvest Oranı %",  group="Reinvest", minval=0, maxval=100, step=5)

// ─── Tarih Aralığı ───────────────────────────────────────────────
useRange  = input.bool(false, "Tarih Araligi Kullan", group="Tarih")
startDate = input.time(timestamp("2020-01-01 00:00"), "Baslangic", group="Tarih")
endDate   = input.time(timestamp("2030-01-01 00:00"), "Bitis",     group="Tarih")
inRange   = not useRange or (time >= startDate and time <= endDate)

// ─── Durum değişkenleri ──────────────────────────────────────────
var float entryPrice = na      // mevcut döngünün ilk alım fiyatı
var int   filledSO   = 0       // dolan güvenlik emri sayısı
var bool  ttpActive  = false
var float ttpPeak    = na
var float dynBase    = na      // reinvest ile büyüyen base tutarı
var float dynSafe    = na      // reinvest ile büyüyen safety tutarı
var bool  pendingReinvest = false  // kapanan döngünün kârı işlenmeyi bekliyor
var int   dealStartT = na      // mevcut döngünün açılış zamanı
var float sumHold    = 0.0     // kapanan döngülerin toplam tutma süresi (gün)
var int   holdN      = 0       // kapanan döngü sayısı

if na(dynBase)
    dynBase := baseOrder
    dynSafe := safeOrder

avg   = strategy.position_avg_price
inPos = strategy.position_size > 0

var int firstBarT = na          // ilk yüklenen mum zamanı
if na(firstBarT)
    firstBarT := time

// ─── SO tetik fiyatı (0-tabanlı n) — uygulamayla birebir ─────────
// cumPct tam hassasiyetle birikir, kullanılan değer 2 ondalığa kırpılır (3Commas)
soPrice(n) =>
    cum = 0.0
    st  = priceStep
    for i = 0 to n
        cum := cum + st
        st  := st * stepMult
    cumF = math.floor(cum * 100) / 100
    entryPrice * (1 - cumF / 100)

// ─── Döngü başına toplam sermaye (base + tüm SO'lar) ─────────────
totalOrderBase(init, safe) =>
    t = init
    if maxSO > 0
        for n = 0 to maxSO - 1
            t := t + safe * math.pow(volMult, n)
    t

// ═══════════════════════ İŞLEM MANTIĞI ══════════════════════════

// 1) Pozisyon yoksa → (tarih aralığındaysa) → reinvest uygula → Base Order aç
if not inPos
    if inRange
        // Bir önceki döngü kapandıysa, motorun gerçekleşen kârından reinvest yap
        if pendingReinvest
            profit = strategy.closedtrades.profit(strategy.closedtrades - 1)
            if reinvest and profit > 0
                add  = profit * reinvestPct / 100
                base = totalOrderBase(dynBase, dynSafe)
                if base > 0
                    ratio   = (base + add) / base
                    dynBase := dynBase * ratio
                    dynSafe := dynSafe * ratio
            pendingReinvest := false

        entryPrice := close
        filledSO   := 0
        ttpActive  := false
        ttpPeak    := na
        dealStartT := time
        strategy.entry("DCA", strategy.long, qty = dynBase / close)

// 2) Pozisyon varsa → önce TP, sonra SO doldurma (uygulama sırası)
else
    tpPrice = avg * (1 + tpPct / 100)
    closed  = false

    if useTTP
        if not ttpActive and close >= tpPrice
            ttpActive := true
            ttpPeak   := close
        if ttpActive
            ttpPeak := math.max(ttpPeak, close)
            if close <= ttpPeak * (1 - ttpPct / 100)
                strategy.close("DCA", comment="TTP")
                closed := true
    else
        if close >= tpPrice
            strategy.close("DCA", comment="TP")
            closed := true

    if closed
        pendingReinvest := true   // kâr bir sonraki bar (pozisyon kapanınca) işlenir
        if not na(dealStartT)
            sumHold := sumHold + (time - dealStartT) / 86400000.0
            holdN   := holdN + 1

    // TP olmadıysa güvenlik emirlerini doldur
    if not closed and filledSO < maxSO
        for n = filledSO to maxSO - 1
            if close <= soPrice(n)
                amt = dynSafe * math.pow(volMult, n)
                strategy.entry("DCA", strategy.long, qty = amt / close)
                filledSO := n + 1
            else
                break

// ─── Görsel: ortalama maliyet & TP çizgileri ─────────────────────
plot(inPos ? avg : na,                     "Avg Cost", color.orange, 2, plot.style_linebr)
plot(inPos ? avg * (1 + tpPct / 100) : na, "TP",       color.green,  1, plot.style_linebr)

// ─── Sonuç paneli (grafik üzerinde) ──────────────────────────────
showPanel = input.bool(true, "Sonuc Panelini Goster", group="Panel")
var table t = table.new(position.top_right, 2, 10, border_width=1, frame_width=1, frame_color=color.gray)
if showPanel and barstate.islast
    netP   = strategy.netprofit
    netPct = strategy.netprofit / strategy.initial_capital * 100
    wr     = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100 : 0
    pcol   = netP >= 0 ? color.green : color.red
    bg     = color.new(color.black, 20)
    table.cell(t, 0, 0, "DCA SONUC", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.normal)
    table.cell(t, 1, 0, "", bgcolor=color.new(color.blue, 0))
    table.cell(t, 0, 1, "Net Kar",    text_color=color.gray,  bgcolor=bg)
    table.cell(t, 1, 1, str.tostring(netP, "#.##") + "  (" + str.tostring(netPct, "#.##") + "%)", text_color=pcol, bgcolor=bg)
    table.cell(t, 0, 2, "Islem",      text_color=color.gray,  bgcolor=bg)
    table.cell(t, 1, 2, str.tostring(strategy.closedtrades),  text_color=color.white, bgcolor=bg)
    table.cell(t, 0, 3, "Kazanma %",  text_color=color.gray,  bgcolor=bg)
    table.cell(t, 1, 3, str.tostring(wr, "#.#") + "%",        text_color=color.white, bgcolor=bg)
    table.cell(t, 0, 4, "Max DD",     text_color=color.gray,  bgcolor=bg)
    table.cell(t, 1, 4, str.tostring(strategy.max_drawdown, "#.##"), text_color=color.red, bgcolor=bg)
    table.cell(t, 0, 5, "Acik SO",    text_color=color.gray,  bgcolor=bg)
    table.cell(t, 1, 5, str.tostring(filledSO) + "/" + str.tostring(maxSO), text_color=color.white, bgcolor=bg)
    table.cell(t, 0, 6, "Bakiye",     text_color=color.gray,  bgcolor=bg)
    table.cell(t, 1, 6, str.tostring(strategy.equity, "#.##"), text_color=color.white, bgcolor=bg)
    avgHold  = holdN > 0 ? sumHold / holdN : 0.0
    openDays = inPos and not na(dealStartT) ? (time - dealStartT) / 86400000.0 : 0.0
    table.cell(t, 0, 7, "Ort. Tutma", text_color=color.gray,  bgcolor=bg)
    table.cell(t, 1, 7, str.tostring(avgHold, "#.#") + " gun",  text_color=color.white, bgcolor=bg)
    table.cell(t, 0, 8, "Acik Sure",  text_color=color.gray,  bgcolor=bg)
    table.cell(t, 1, 8, inPos ? str.tostring(openDays, "#.#") + " gun" : "-", text_color=color.white, bgcolor=bg)
    dRange = str.format_time(firstBarT, "yyyy-MM-dd", syminfo.timezone) + " > " + str.format_time(time, "yyyy-MM-dd", syminfo.timezone)
    table.cell(t, 0, 9, "Tarih",      text_color=color.gray,  bgcolor=bg)
    table.cell(t, 1, 9, dRange,       text_color=color.white, bgcolor=bg, text_size=size.small)
